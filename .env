# ==================== DATABASE ====================
MONGODB_URI=mongodb://localhost:27017/workspace-reseller
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/workspace-reseller

# ==================== SERVER ====================
PORT=5000
NODE_ENV=development

# ==================== JWT ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# ==================== EMAIL CONFIGURATION ====================
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Note: For Gmail, you need to:
# 1. Enable 2-Factor Authentication
# 2. Generate an App Password (not your regular Gmail password)
# 3. Use the App Password here

# ==================== GOOGLE WORKSPACE ====================
# Service Account JSON from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-google-project-id

# Replace \n with actual line breaks from the JSON file

# ==================== GOOGLE VOICE ====================
GOOGLE_ACCOUNT_ID=your-google-account-id
GOOGLE_VOICE_API_KEY=your-voice-api-key

# ==================== PAYMENT GATEWAY - STRIPE ====================
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# ==================== PAYMENT GATEWAY - PAYPAL ====================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox
# Change to: PAYPAL_MODE=live (for production)

# ==================== AWS (OPTIONAL - FOR FILE STORAGE) ====================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name

# ==================== SENDGRID (OPTIONAL - ALTERNATIVE EMAIL) ====================
SENDGRID_API_KEY=your-sendgrid-api-key

# ==================== TWILIO (OPTIONAL - FOR SMS NOTIFICATIONS) ====================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ==================== BUSINESS SETTINGS ====================
BUSINESS_NAME="Google Workspace Reseller"
BUSINESS_EMAIL=support@yourreseller.com
BUSINESS_PHONE=+1-xxx-xxx-xxxx
BUSINESS_WEBSITE=https://yourreseller.com

# ==================== PRICING CONFIGURATION ====================
# Mark-up percentage (e.g., 20 for 20% markup)
WORKSPACE_MARKUP=20
VOICE_MARKUP=15

# ==================== LOGGING ====================
LOG_LEVEL=info
# Options: error, warn, info, debug

# ==================== CORS ====================
CORS_ORIGIN=http://localhost:3000
# For production: CORS_ORIGIN=https://yourdomain.com

# ==================== ADMIN CREDENTIALS ====================
ADMIN_EMAIL=admin@yourreseller.com
ADMIN_PASSWORD=change-this-to-secure-password

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== SESSION ====================
SESSION_SECRET=your-session-secret-key
SESSION_TIMEOUT=86400000

# ==================== GOOGLE OAUTH (OPTIONAL - FOR SSO) ====================
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ==================== SLACK NOTIFICATIONS (OPTIONAL) ====================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==================== ANALYTICS (OPTIONAL) ====================
GOOGLE_ANALYTICS_ID=UA-XXXXX-Y

# ==================== CACHE ====================
REDIS_URL=redis://localhost:6379
# Leave empty to disable caching

# ==================== API KEYS ====================
INTERNAL_API_KEY=your-internal-api-key-for-webhooks
